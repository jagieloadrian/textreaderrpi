# ============================================================
# TextReaderRpi — Environment Variables Template
# Copy to .env.local and fill in your values.
# All variables have defaults in application.yaml — only
# override what differs from the defaults.
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=8080

# ── Database ─────────────────────────────────────────────────
# H2 embedded (default — suitable for RPi without external DB):
DATABASE_URL=jdbc:h2:file:./data/schedules;DB_CLOSE_DELAY=-1;AUTO_SERVER=FALSE
DATABASE_DRIVER=org.h2.Driver
DATABASE_USER=sa
DATABASE_PASSWORD=
DATABASE_POOL_SIZE=5

# PostgreSQL (uncomment and fill in for production):
# DATABASE_URL=jdbc:postgresql://localhost:5432/textreader
# DATABASE_DRIVER=org.postgresql.Driver
# DATABASE_USER=textreader
# DATABASE_PASSWORD=secret
# DATABASE_POOL_SIZE=10

# ── Display ──────────────────────────────────────────────────
# Options: MAX7219, LCD, OLED
DISPLAY_TYPE=MAX7219
MAX7219_NUM_DEVICES=2
GPIO_SPI_CE=8
GPIO_SPI_MOSI=10
GPIO_SPI_MISO=9
GPIO_SPI_SCK=11
I2C_BUS=1

# ── Hardware timeouts ─────────────────────────────────────────
SPI_TIMEOUT_MS=1000
GPIO_TIMEOUT_MS=500

# ── API / Rate limiting ───────────────────────────────────────
API_MAX_TEXT_LENGTH=128
API_QUEUE_SIZE=10
API_RATE_LIMIT=60
API_METRICS_RATE_LIMIT=120

# ── Retry policy ──────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=5
RETRY_INITIAL_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000
RETRY_FACTOR=2.0

# ── Metrics ───────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PREFIX=textreaderrpi

# ── Resources & Timing ────────────────────────────────────────
SCREEN_DRIVER_MAX_SLOTS=10
SCROLL_SPEED=16
REFRESH_RATE=60

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

